{
  "name": "quote-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "expo": "~57.0.7",
    "expo-constants": "~57.0.6",
    "expo-crypto": "~57.0.1",
    "expo-dev-client": "~57.0.7",
    "expo-document-picker": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-image-picker": "~57.0.5",
    "expo-linking": "~57.0.3",
    "expo-print": "~57.0.1",
    "expo-router": "~57.0.7",
    "expo-sharing": "~57.0.6",
    "expo-splash-screen": "~57.0.4",
    "expo-sqlite": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "expo-symbols": "~57.0.1",
    "expo-updates": "~57.0.8",
    "expo-web-browser": "~57.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "tsx": "^4.23.1",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "check": "npx tsc --noEmit && npx tsx scripts/check-calc.ts && npx tsx scripts/check-products.ts && npx tsx scripts/check-quotes.ts && npx tsx scripts/check-quote-numbers.ts && npx tsx scripts/check-business-settings.ts && npx tsx scripts/check-pdf.ts && npx tsx scripts/check-duplicate.ts && npx tsx scripts/check-seed-guard.ts",
    "build:android:preview": "npx eas-cli build --platform android --profile preview --non-interactive",
    "build:android:production": "npx eas-cli build --platform android --profile production --non-interactive",
    "build:ios:preview": "npx eas-cli build --platform ios --profile preview",
    "build:ios:production": "npx eas-cli build --platform ios --profile production",
    "submit:ios": "npx eas-cli submit --platform ios --profile production"
  },
  "private": true
}
